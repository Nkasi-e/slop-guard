# SlopGuard environment configuration example
#
# Copy this file to `.env` (or export the variables in your shell/CI) and
# adjust values as needed. The VS Code extension does NOT read `.env` directly;
# use this as documentation for environment variables you configure.

############################################
# Engine-related settings (optional)
############################################

# Explicit path to the compiled Rust engine binary (overrides auto-detection).
# Example (macOS/Linux):
# SLOP_GUARD_ENGINE_PATH=/absolute/path/to/slopguard/engine/target/debug/slopguard-engine

############################################
# LLM enrichment (optional)
############################################
#
# The extension only uses these when:
# - `slopguard.llm.enabled` is true in editor settings, AND
# - at least one API key env var below is set.
#
# Priority order for API keys:
# 1) SLOP_GUARD_LLM_API_KEY
# 2) OPENROUTER_API_KEY
# 3) OPENAI_API_KEY
#
# Endpoint/model defaults:
# - If OPENROUTER_API_KEY is set:
#     endpoint = https://openrouter.ai/api/v1/chat/completions
#     default model = anthropic/claude-3.5-sonnet
# - Else if OPENAI_API_KEY is set:
#     endpoint = https://api.openai.com/v1/chat/completions
#     default model = gpt-4o-mini
# - Else if SLOP_GUARD_LLM_API_KEY is set and SLOP_GUARD_LLM_ENDPOINT is set:
#     endpoint = SLOP_GUARD_LLM_ENDPOINT
#     model comes from `slopguard.llm.model` setting (or its default)

# Generic override key used by SlopGuard (highest priority).
# SLOP_GUARD_LLM_API_KEY=sk-...

# Optional custom endpoint when using SLOP_GUARD_LLM_API_KEY.
# Must be OpenAI-compatible `chat/completions`.
# SLOP_GUARD_LLM_ENDPOINT=https://your-gateway.example.com/v1/chat/completions

# OpenRouter API key (second priority if SLOP_GUARD_LLM_API_KEY is not set).
# OPENROUTER_API_KEY=sk-or-...

# OpenAI API key (third priority if others are not set).
# OPENAI_API_KEY=sk-...

